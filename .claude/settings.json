{
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "Skill(simplify)",
      "Bash(./sync.sh ~/Downloads/\"MX\\(2\\).zip\" app_mocks)"
